# Project URL only — do NOT include /rest/v1
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth credentials go in Supabase Dashboard (Authentication → Providers → Google),
# NOT in this file. The Next.js app never reads Google client ID/secret directly.

# Direct Postgres — npm run db:test-connection && npm run db:apply-hsk
# Password reset: https://supabase.com/dashboard/project/whfpbavfizsviaksevru/settings/database
#
# Option A — paste full URI from Supabase Connect → Session pooler (recommended on home WiFi):
# DATABASE_URL=postgresql://postgres.whfpbavfizsviaksevru:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# Option B — password + region (region is in the pooler hostname, e.g. us-west-1):
# SUPABASE_DB_PASSWORD=your_password
# SUPABASE_DB_REGION=us-west-1
